@using PoeShared.Blazor.Scaffolding
@using YoloEase.UI.Core
@inherits PoeShared.Blazor.BlazorReactiveComponent<MainWindowViewModel>

<TabPageLayout Class="settings-tab" BodyClass="ye-settings">
    <TopBar>
        <div class="ye-tab-title-row">
            <span class="ye-tab-title">@GetSettingsTitle()</span>
            <span class="ye-tab-subtitle">@GetSettingsSubtitle()</span>
        </div>
    </TopBar>

    <ChildContent>
    @{
        var project = Track(x => x.YoloEaseProject);
    }
    @if (project.IsEmpty)
    {
        <section class="ye-section">
            <div class="alert alert-secondary mb-0">No project loaded.</div>
        </section>
    }
    else
    {
        var remoteProject = project.RemoteProject;
        var trainingDataset = project.TrainingDataset;

        <section class="ye-section">
            <div class="ye-section-header">
                <h4>Annotation backend</h4>
            </div>

            <div class="ye-field">
                <label class="ye-field-label">Backend</label>
                <div class="ye-field-control">
                    <div class="form-control-plaintext">Offline</div>
                </div>
            </div>

            <ReactiveSection Trackers="@(new() { remoteProject.WhenAnyValue(x => x.Mode, x => x.CurrentUser, x => x.IsBusy) })">
                <div class="ye-field">
                    <label for="offlineUsername" class="ye-field-label">Operator</label>
                    <div class="ye-field-control">
                        <InputTextEx type="text" class="form-control" id="offlineUsername" placeholder="Displayed as the local editor user" @bind-Value="@remoteProject.Username"/>
                    </div>
                </div>

                <div class="ye-field">
                    <div class="ye-field-label"></div>
                    <div class="ye-field-control ye-status-row">
                        <span class="text-success">offline workspace ready</span>
                        <div class="flex-grow-1"></div>
                        <ReactiveButton Class="btn btn-link" Command="@(() => remoteProject.Refresh())">
                            <i class="fa fa-refresh"></i>
                            Refresh
                        </ReactiveButton>
                    </div>
                </div>

                <div class="ye-field">
                    <label class="ye-field-label">
                        @if (Track(remoteProject, x => x.IsBusy))
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                        }
                        Workspace
                    </label>
                    <div class="ye-field-control">
                        <div class="input-group">
                            <ReactiveButton Class="btn btn-outline-secondary"
                                            Command="@(async () => await ProcessUtils.OpenFolder(project.StorageDirectory))">
                                <i class="fa fa-folder-open"></i>
                            </ReactiveButton>
                            <span class="input-group-text ye-path">@project.StorageDirectory?.FullName</span>
                            <ReactiveButton Class="btn btn-outline-secondary" Command="@DataContext.OpenProject">
                                <i class="fa fa-link"></i>
                                Open
                            </ReactiveButton>
                        </div>
                    </div>
                </div>
            </ReactiveSection>

            <div class="ye-field">
                <label class="ye-field-label">
                    @if (Track(remoteProject, x => x.IsBusy))
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                    }
                    Labels
                </label>
                <div class="ye-field-control">
                    @if (remoteProject.Labels.Count <= 0)
                    {
                        <div class="alert alert-secondary mb-0">No labels available</div>
                    }
                    else
                    {
                        <div class="ye-labels">
                            @foreach (var label in remoteProject.Labels.Items.OrderBy(x => x.Name))
                            {
                                <div class="ye-label-pill">
                                    <span class="ye-label-swatch" style="background-color: @(label.Color);"></span>
                                    <span>@label.Name</span>
                                </div>
                            }
                        </div>
                    }

                    <div class="form-text mt-2">Manage offline labels and their colors from the Project tab.</div>
                </div>
            </div>

            <div class="ye-field">
                <label class="ye-field-label">Stats</label>
                <div class="ye-field-control ye-inline-stats">
                    <span>@($"{remoteProject.Tasks.Count} tasks")</span>
                    <span>@($"{remoteProject.ProjectFiles.Count} files")</span>
                </div>
            </div>
        </section>

        <section class="ye-section">
            <div class="ye-section-header">
                <h4>Training settings</h4>
            </div>

            <div class="ye-field">
                <label for="modelPath" class="ye-field-label">Yolo8/10+ base model</label>
                <div class="ye-field-control">
                    <div class="input-group">
                        <InputTextEx type="text" class="form-control" id="modelPath" placeholder="Yolo8 base model path" @bind-Value="@trainingDataset.BaseModelPath"/>
                        <ReactiveButton Class="btn btn-outline-secondary" Command="@DataContext.SelectModel">
                            ...
                        </ReactiveButton>
                    </div>
                </div>
            </div>

            <div class="ye-field ye-field-compact">
                <label for="epochs" class="ye-field-label">Epochs</label>
                <div class="ye-field-control">
                    <input type="number" class="form-control ye-number" id="epochs"
                           min="1" step="1"
                           value="@Track(trainingDataset, x => x.Epochs)"
                           @oninput="@((ChangeEventArgs x) => trainingDataset.Epochs = x.Value is not string valueAsString || string.IsNullOrEmpty(valueAsString) ? 1 : Convert.ToInt32(valueAsString))">
                    <span class="ye-help">usually 50-200 is a good choice</span>
                </div>
            </div>

            <div class="ye-field ye-field-compact">
                <label for="modelSize" class="ye-field-label">Model Size</label>
                <div class="ye-field-control">
                    <input type="number" class="form-control ye-number" id="modelSize"
                           min="32" step="32"
                           value="@Track(trainingDataset, x => x.ModelSize)"
                           @oninput="@((ChangeEventArgs x) => trainingDataset.ModelSize = x.Value is not string valueAsString || string.IsNullOrEmpty(valueAsString) ? 1 : Convert.ToInt32(valueAsString))">
                    <span class="ye-help">640 is default value and should fit most use cases</span>
                </div>
            </div>

            <div class="ye-field ye-field-compact">
                <label for="maxCpuCores" class="ye-field-label">Max CPU Cores</label>
                <div class="ye-field-control">
                    <ReactiveSection Trackers="@(new ReactiveTrackerList().With(trainingDataset.WhenAnyValue(x => x.MaxNumberOfCpuCores)))">
                        <input type="range" class="form-range ye-range" id="maxCpuCores"
                               min="0"
                               max="@(Environment.ProcessorCount)"
                               value="@trainingDataset.MaxNumberOfCpuCores"
                               @oninput="@((ChangeEventArgs x) => trainingDataset.MaxNumberOfCpuCores = x.Value is not string valueAsString ? 0 : Convert.ToInt32(valueAsString))">
                        <span class="ye-range-value">@($"{(trainingDataset.MaxNumberOfCpuCores <= 0 ? "Any" : trainingDataset.MaxNumberOfCpuCores)}")</span>
                    </ReactiveSection>
                </div>
            </div>

            <div class="ye-field">
                <label for="trainAdditionalArguments" class="ye-field-label">Additional arguments</label>
                <div class="ye-field-control">
                    <InputTextEx type="text" class="form-control" id="trainAdditionalArguments" placeholder="command line arguments..." @bind-Value="@trainingDataset.TrainAdditionalArguments"/>
                </div>
            </div>
        </section>

        <section class="ye-section">
            <div class="ye-section-header">
                <h4>Application settings</h4>
            </div>

            <div class="ye-field">
                <label class="ye-field-label">Project folder</label>
                <div class="ye-field-control">
                    <div class="input-group">
                        <span class="input-group-text ye-path">@DataContext.ProjectDirectory?.FullName</span>
                    </div>
                </div>
            </div>

            <div class="ye-field">
                <label for="storageProjectSubfolder" class="ye-field-label">Storage subfolder</label>
                <div class="ye-field-control">
                    <div class="input-group">
                        <InputTextEx type="text" class="form-control" id="storageProjectSubfolder"
                                     placeholder="Project-owned storage subfolder"
                                     @bind-Value="@DataContext.PendingStorageProjectSubfolder"/>
                        <ReactiveButton Class="btn btn-primary" Command="@DataContext.ApplyStorageProjectSubfolder">
                            Apply
                        </ReactiveButton>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Track(x => x.StorageProjectSubfolderError)))
                    {
                        <div class="form-text text-danger">@DataContext.StorageProjectSubfolderError</div>
                    }
                    else
                    {
                        <div class="form-text">Relative to the project file. Absolute paths and parent-folder escapes are not allowed.</div>
                    }
                </div>
            </div>

            <div class="ye-field">
                <label for="directoryPath" class="ye-field-label">Resolved storage</label>
                <div class="ye-field-control">
                    <div class="input-group">
                        <ReactiveButton Class="btn btn-outline-secondary" Command="@DataContext.OpenStorage">
                            <i class="fa fa-folder-open"></i>
                        </ReactiveButton>
                        <span class="input-group-text ye-path">@DataContext.ProjectOutputDirectory?.FullName</span>
                    </div>
                </div>
            </div>
        </section>
    }
    </ChildContent>
</TabPageLayout>

@code {
    private string GetSettingsTitle()
    {
        var project = GetCurrentProject();
        var projectName = project?.RemoteProject.ProjectName;
        if (!string.IsNullOrWhiteSpace(projectName))
        {
            return projectName.Trim();
        }

        var loadedProjectName = DataContext.LoadedProjectFile == null
            ? null
            : Path.GetFileNameWithoutExtension(DataContext.LoadedProjectFile.Name);

        return string.IsNullOrWhiteSpace(loadedProjectName) ? "Project" : loadedProjectName;
    }

    private string GetSettingsSubtitle()
    {
        var project = GetCurrentProject();
        if (project == null)
        {
            return "No project";
        }

        return "Offline backend";
    }

    private YoloEaseProject? GetCurrentProject()
    {
        var project = Track(x => x.YoloEaseProject);
        return project.IsEmpty ? null : project;
    }

}
