@using AntDesign
@using System.Reactive.Linq
@using System.Threading
@using PoeShared.Blazor.Scaffolding
@using PoeShared.Blazor.Wpf
@using PoeShared.Services
@using YoloEase.UI.Core
@using YoloEase.UI.Dto
@inherits YoloEaseComponent<YoloEaseProject>

<TabPageLayout Class="tasks-tab"
               BodyClass="tasks-page"
               ProgressVisible="@IsTasksRefreshing"
               ProgressIndeterminate="true"
               ProgressText="Refreshing tasks">
    <TopBar>
        <div class="ye-tab-title-row">
            <span class="ye-tab-title">Tasks</span>
            <span class="ye-tab-subtitle">@DataContext.RemoteProject.ProjectName</span>
        </div>

        <div class="tasks-stats">
            <span class="badge text-bg-secondary">@($"{DataContext.RemoteProject.Tasks.Count} tasks")</span>
            <span class="badge text-bg-success">@($"{DataContext.RemoteProject.Tasks.Items.Count(x => x.Status == AnnotationTaskStatus.Completed)} completed")</span>
            <span class="badge text-bg-secondary">@($"{DataContext.RemoteProject.ProjectFiles.Count} files")</span>
            @if (isLabelStatsRefreshing)
            {
                <span class="badge text-bg-secondary">
                    <span class="spinner-border spinner-border-sm"></span>
                    labels
                </span>
            }
        </div>

        <div class="tasks-filter">
            <RadioGroup @bind-Value="taskFilter" Size="@(AntSizeLDSType.Small)">
                <Radio Value="@(TaskListFilter.Open)">Open</Radio>
                <Radio Value="@(TaskListFilter.Completed)">Completed</Radio>
                <Radio Value="@(TaskListFilter.All)">All</Radio>
            </RadioGroup>
        </div>

        <div class="flex-grow-1"></div>

        <ReactiveButton Class="btn btn-outline-secondary btn-sm"
                        Command="@(async () => await RefreshTasks())">
            <i class="fa fa-refresh"></i>
            Refresh
        </ReactiveButton>
    </TopBar>

    <ChildContent>
        @{
            var labelSummaries = GetProjectLabelSummaries().ToArray();
        }
        @if (labelSummaries.Length > 0 || !string.IsNullOrWhiteSpace(labelStatsError))
        {
            <section class="tasks-label-summary">
                <div class="tasks-label-summary-title">
                    <span>Labels</span>
                    @if (labelStatisticsSnapshot is { } snapshot)
                    {
                        <small>@($"{snapshot.TotalAnnotations} total")</small>
                    }
                    @if (!string.IsNullOrWhiteSpace(labelStatsError))
                    {
                        <small class="text-warning">@labelStatsError</small>
                    }
                </div>
                @if (labelSummaries.Length > 0)
                {
                    <div class="tasks-label-pills">
                        @foreach (var label in labelSummaries)
                        {
                            <span class="tasks-label-pill" title="@FormatLabelSummaryTooltip(label, labelStatisticsSnapshot?.TotalFiles ?? 0)">
                                <span class="tasks-label-dot" style="@($"background-color:{label.Color};")"></span>
                                <span class="tasks-label-name">@label.LabelName</span>
                                <span class="tasks-label-count">@label.AnnotationCount</span>
                                <span class="tasks-label-percent">@FormatPercent(label.FilePercent)</span>
                            </span>
                        }
                    </div>
                }
            </section>
        }

        @if (DataContext.RemoteProject.Tasks.Count <= 0)
        {
            <div class="alert alert-secondary mb-0">
                No tasks yet.
            </div>
        }
        else
        {
            var visibleTasks = GetVisibleTasks().ToArray();
            if (visibleTasks.Length <= 0)
            {
                <div class="alert alert-secondary mb-0">
                    No tasks match the current filter.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle tasks-table">
                        <thead>
                        <tr>
                            <th>Task</th>
                            <th>Status</th>
                            <th class="text-end">Files</th>
                            <th>Labels</th>
                            <th>Updated</th>
                            <th class="text-end">Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var task in visibleTasks)
                        {
                            var localTask = task;
                            <tr @key="localTask.Id" class="@GetTaskRowClass(localTask)">
                                <td>
                                    <div>@localTask.Name</div>
                                </td>
                                <td>
                                    @if (DataContext.RemoteProject.Mode == AnnotationBackendMode.Offline)
                                    {
                                        <select @key="localTask.Status"
                                                class="@GetStatusSelectClass(localTask.Status)"
                                                value="@((int) localTask.Status)"
                                                @onchange="@(async args => await SetTaskStatus(localTask.Id, args))">
                                            <option value="@((int) AnnotationTaskStatus.New)">New</option>
                                            <option value="@((int) AnnotationTaskStatus.InProgress)">In progress</option>
                                            <option value="@((int) AnnotationTaskStatus.Completed)">Completed</option>
                                        </select>
                                    }
                                    else
                                    {
                                        <span class="@GetStatusClass(localTask.Status)">@FormatStatus(localTask.Status)</span>
                                    }
                                </td>
                                <td class="text-end">@GetTaskFileCount(localTask.Id)</td>
                                <td>
                                    @{
                                        var taskLabelStats = GetTaskLabelStatistics(localTask.Id);
                                    }
                                    @if (taskLabelStats == null)
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(taskLabelStats.Error))
                                    {
                                        <span class="tasks-label-warning" title="@FormatTaskLabelTooltip(taskLabelStats)">
                                            <i class="fa fa-warning"></i>
                                            unavailable
                                        </span>
                                    }
                                    else if (taskLabelStats.AnnotationCount <= 0)
                                    {
                                        <span class="text-muted" title="@FormatTaskLabelTooltip(taskLabelStats)">-</span>
                                    }
                                    else
                                    {
                                        <div class="tasks-label-dots" title="@FormatTaskLabelTooltip(taskLabelStats)">
                                            @foreach (var label in taskLabelStats.Labels.Take(MaxTaskLabelDots))
                                            {
                                                <span class="tasks-label-dot-item">
                                                    <span class="tasks-label-dot" style="@($"background-color:{label.Color};")"></span>
                                                    <span>@label.AnnotationCount</span>
                                                </span>
                                            }
                                            @if (taskLabelStats.Labels.Count > MaxTaskLabelDots)
                                            {
                                                <span class="tasks-label-more">@($"+{taskLabelStats.Labels.Count - MaxTaskLabelDots}")</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="text-muted small">@FormatDate(localTask.UpdatedAt ?? localTask.CreatedAt)</td>
                                <td class="text-end">
                                    <div class="ye-row-actions">
                                        <ReactiveButton Class="btn btn-outline-secondary btn-sm ye-action-open"
                                                        Command="@(async () => await OpenTask(localTask.Id))">
                                            <i class="fa fa-external-link"></i>
                                            Open
                                        </ReactiveButton>
                                        <div class="ye-two-step-group ye-two-step-group--compact">
                                            @if (pendingDeleteTaskId == localTask.Id)
                                            {
                                                <ReactiveButton Class="btn btn-danger btn-sm ye-two-step-confirm"
                                                                title="Confirm delete task"
                                                                Command="@(async () => await DeleteTask(localTask.Id))">
                                                    <i class="fa fa-check"></i>
                                                </ReactiveButton>
                                                <button type="button" class="btn btn-secondary btn-sm ye-two-step-cancel" title="Cancel delete" @onclick="CancelDeleteTask">
                                                    <i class="fa fa-times"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-outline-danger btn-sm ye-two-step-primary" @onclick="() => BeginDeleteTask(localTask.Id)">
                                                    <i class="fa fa-trash"></i>
                                                    Delete
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        }
    </ChildContent>
</TabPageLayout>

@code {
    private const int MaxTaskLabelDots = 8;

    [Inject]
    protected INotificationService NotificationService { get; init; } = default!;

    [Inject]
    protected IFactory<IBlazorWindow, System.Windows.Threading.Dispatcher> BlazorWindowFactory { get; init; } = default!;

    [Inject]
    protected IBlazorWindowAccessor BlazorWindowAccessor { get; init; } = default!;

    private int? pendingDeleteTaskId;
    private TaskListFilter taskFilter = TaskListFilter.Open;
    private int labelStatsRefreshVersion;
    private bool isLabelStatsRefreshing;
    private string? labelStatsError;
    private TaskLabelStatisticsSnapshot? labelStatisticsSnapshot;
    private IReadOnlyDictionary<int, TaskLabelStatistics> labelStatisticsByTask = new Dictionary<int, TaskLabelStatistics>();
    private IDisposable? taskStatisticsRefreshSubscription;
    private readonly SemaphoreSlim labelStatisticsRefreshGate = new(1, 1);

    public TasksList()
    {
        ChangeTrackers.Add(this.WhenAnyValue(x => x.DataContext.RemoteProject.Tasks.Count));
        ChangeTrackers.Add(this.WhenAnyValue(x => x.DataContext.RemoteProject.ProjectFiles.Count));
        ChangeTrackers.Add(this.WhenAnyValue(x => x.DataContext.RemoteProject.Labels.Count));
        ChangeTrackers.Add(this.WhenAnyValue(x => x.DataContext.RemoteProject.ActiveTaskId));
        ChangeTrackers.Add(this.WhenAnyValue(x => x.DataContext.IsBusy));
        ChangeTrackers.Add(this.WhenAnyValue(x => x.DataContext.RemoteProject.IsBusy));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (firstRender)
        {
            SubscribeToTaskStatisticsUpdates();
            await RefreshLabelStatistics();
        }
    }

    private void SubscribeToTaskStatisticsUpdates()
    {
        if (taskStatisticsRefreshSubscription != null)
        {
            return;
        }

        taskStatisticsRefreshSubscription = new CompositeDisposable(
            DataContext.RemoteProject.Tasks.Connect().Skip(1).Subscribe(_ => QueueTaskStatisticsRefresh()),
            DataContext.RemoteProject.ProjectFiles.Connect().Skip(1).Subscribe(_ => QueueTaskStatisticsRefresh()),
            DataContext.RemoteProject.Labels.Connect().Skip(1).Subscribe(_ => QueueTaskStatisticsRefresh()));
        taskStatisticsRefreshSubscription.AddTo(Anchors);
    }

    private void QueueTaskStatisticsRefresh()
    {
        InvokeAsync(async () =>
        {
            StateHasChanged();
            await RefreshLabelStatistics();
        }).AndForget();
    }

    private async Task RefreshTasks()
    {
        try
        {
            await DataContext.Refresh();
            await RefreshLabelStatistics();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception e)
        {
            ShowError(e.Message);
        }
    }

    private async Task OpenTask(int taskId)
    {
        try
        {
            var task = DataContext.RemoteProject.Tasks.Items.FirstOrDefault(x => x.Id == taskId);
            if (task == null)
            {
                return;
            }

            await TaskAnnotationWindowLauncher.Open(DataContext, task, BlazorWindowAccessor, BlazorWindowFactory);
        }
        catch (Exception e)
        {
            ShowError(e.Message);
        }
    }

    private async Task DeleteTask(int taskId)
    {
        try
        {
            await DataContext.RemoteProject.DeleteTask(taskId);
            pendingDeleteTaskId = null;
            await DataContext.Refresh();
            await RefreshLabelStatistics();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception e)
        {
            ShowError(e.Message);
        }
    }

    private void BeginDeleteTask(int taskId)
    {
        pendingDeleteTaskId = taskId;
    }

    private void CancelDeleteTask()
    {
        pendingDeleteTaskId = null;
    }

    private async Task SetTaskStatus(int taskId, ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var rawStatus))
        {
            return;
        }

        try
        {
            await DataContext.RemoteProject.UpdateTaskStatus(taskId, (AnnotationTaskStatus) rawStatus);
            await DataContext.Refresh();
            await RefreshLabelStatistics();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception e)
        {
            ShowError(e.Message);
        }
    }

    private int GetTaskFileCount(int taskId)
    {
        return DataContext.RemoteProject.ProjectFiles.Items.Count(x => x.TaskId == taskId);
    }

    private async Task RefreshLabelStatistics()
    {
        var refreshVersion = Interlocked.Increment(ref labelStatsRefreshVersion);
        isLabelStatsRefreshing = true;
        labelStatsError = null;
        await InvokeAsync(StateHasChanged);

        await labelStatisticsRefreshGate.WaitAsync();
        try
        {
            if (refreshVersion != labelStatsRefreshVersion)
            {
                return;
            }

            var remoteProject = DataContext.RemoteProject;
            var tasks = remoteProject.Tasks.Items.ToArray();
            var projectFiles = remoteProject.ProjectFiles.Items.ToArray();
            var projectLabels = remoteProject.Labels.Items.ToArray();
            var annotationsByTask = new Dictionary<int, IReadOnlyList<CvatRectangleAnnotation>>();
            var taskErrors = new Dictionary<int, string>();

            foreach (var task in tasks)
            {
                if (refreshVersion != labelStatsRefreshVersion)
                {
                    return;
                }

                try
                {
                    annotationsByTask[task.Id] = await remoteProject.RetrieveTaskAnnotations(task.Id);
                }
                catch (Exception e) when (e is not OperationCanceledException)
                {
                    Log.Warn($"Failed to load task label statistics for task {task.Id} {task.Name}", e);
                    taskErrors[task.Id] = e.Message;
                    annotationsByTask[task.Id] = Array.Empty<CvatRectangleAnnotation>();
                }
            }

            if (refreshVersion != labelStatsRefreshVersion)
            {
                return;
            }

            var snapshot = TaskLabelStatisticsSnapshot.Create(tasks, projectFiles, projectLabels, annotationsByTask, taskErrors);
            labelStatisticsSnapshot = snapshot;
            labelStatisticsByTask = snapshot.Tasks.ToDictionary(x => x.TaskId);
            labelStatsError = snapshot.FailedTaskCount <= 0
                ? null
                : $"Stats unavailable for {snapshot.FailedTaskCount} task(s)";
        }
        catch (Exception e) when (e is not OperationCanceledException)
        {
            Log.Warn("Failed to refresh task label statistics", e);
            labelStatsError = "Label stats unavailable";
            ShowError(e.Message);
        }
        finally
        {
            labelStatisticsRefreshGate.Release();
            if (refreshVersion == labelStatsRefreshVersion)
            {
                isLabelStatsRefreshing = false;
            }

            await InvokeAsync(StateHasChanged);
        }
    }

    private IEnumerable<LabelUsageStatistics> GetProjectLabelSummaries()
    {
        return labelStatisticsSnapshot?.Labels.Where(x => x.AnnotationCount > 0) ?? Array.Empty<LabelUsageStatistics>();
    }

    private TaskLabelStatistics? GetTaskLabelStatistics(int taskId)
    {
        return labelStatisticsByTask.GetValueOrDefault(taskId);
    }

    private IEnumerable<AnnotationTaskInfo> GetVisibleTasks()
    {
        return DataContext.RemoteProject.Tasks.Items
            .Where(x => taskFilter switch
            {
                TaskListFilter.Open => x.Status != AnnotationTaskStatus.Completed,
                TaskListFilter.Completed => x.Status == AnnotationTaskStatus.Completed,
                _ => true,
            })
            .OrderBy(x => x.Status == AnnotationTaskStatus.Completed)
            .ThenByDescending(x => x.UpdatedAt ?? x.CreatedAt ?? DateTimeOffset.MinValue);
    }

    private string GetTaskRowClass(AnnotationTaskInfo task)
    {
        var classes = new List<string> {GetTaskStateClass(task.Status)};
        if (DataContext.RemoteProject.ActiveTaskId == task.Id)
        {
            classes.Add("table-active");
        }

        return string.Join(" ", classes);
    }

    private bool IsTasksRefreshing => DataContext.IsBusy || DataContext.RemoteProject.IsBusy;

    private static string GetTaskStateClass(AnnotationTaskStatus status)
    {
        return status switch
        {
            AnnotationTaskStatus.Completed => "task-row-completed",
            AnnotationTaskStatus.InProgress => "task-row-in-progress",
            _ => "task-row-new",
        };
    }

    private static string GetStatusSelectClass(AnnotationTaskStatus status)
    {
        return $"form-select form-select-sm tasks-status-select {GetTaskStateClass(status)}";
    }

    private static string FormatDate(DateTimeOffset? date)
    {
        return date == null ? "-" : date.Value.LocalDateTime.ToString("g");
    }

    private static string FormatPercent(double value)
    {
        if (value <= 0)
        {
            return "0%";
        }

        var percent = value * 100;
        return percent < 1
            ? "<1%"
            : $"{Math.Round(percent, MidpointRounding.AwayFromZero):0}%";
    }

    private static string FormatLabelSummaryTooltip(LabelUsageStatistics label, int totalFiles)
    {
        return $"{label.LabelName}: {label.AnnotationCount} label(s) on {label.FileCount} / {totalFiles} file(s) ({FormatPercent(label.FilePercent)})";
    }

    private static string FormatTaskLabelTooltip(TaskLabelStatistics task)
    {
        if (!string.IsNullOrWhiteSpace(task.Error))
        {
            return $"Label stats unavailable: {task.Error}";
        }

        if (task.AnnotationCount <= 0)
        {
            return $"No labels found in {task.FileCount} file(s)";
        }

        var lines = new List<string>
        {
            $"{task.AnnotationCount} label(s) on {task.AnnotatedFileCount} / {task.FileCount} file(s)",
        };
        lines.AddRange(task.Labels.Select(x =>
            $"{x.LabelName}: {x.AnnotationCount} label(s), {x.FileCount} / {task.FileCount} file(s), {FormatPercent(x.FilePercent)}"));
        return string.Join(Environment.NewLine, lines);
    }

    private static string FormatStatus(AnnotationTaskStatus status)
    {
        return status switch
        {
            AnnotationTaskStatus.InProgress => "In progress",
            _ => status.ToString(),
        };
    }

    private static string GetStatusClass(AnnotationTaskStatus status)
    {
        return status switch
        {
            AnnotationTaskStatus.Completed => "badge text-bg-success",
            AnnotationTaskStatus.InProgress => "badge text-bg-warning",
            _ => "badge text-bg-secondary",
        };
    }

    private void ShowError(string message)
    {
        NotificationService.Open(new NotificationConfig
        {
            NotificationType = NotificationType.Error,
            Duration = 8,
            Message = message,
        }).AndForget();
    }

    private enum TaskListFilter
    {
        Open,
        Completed,
        All,
    }
}
