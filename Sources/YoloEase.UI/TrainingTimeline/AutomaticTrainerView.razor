@using PoeShared.Blazor.Scaffolding
@using PoeShared.Blazor.Wpf
@using PoeShared.Services
@using YoloEase.UI.Core
@inherits YoloEaseComponent<AutomaticTrainer>

<TabPageLayout Class="trainer-tab" BodyClass="trainer-page" ScrollBody="false">
    <TopBar>
    <div class="trainer-toolbar">
        <div>
            <ReactiveSection Trackers="@(new ReactiveTrackerList().With(this.WhenAnyValue(x => x.DataContext.IsBusy)))">
                @if (DataContext.IsBusy)
                {
                    <ReactiveButton MinExecutionTime="TimeSpan.Zero" Class="btn btn-link" Command="@DataContext.Stop">
                        <i class="fa fa-stop-circle"></i>
                        Stop automatic training
                    </ReactiveButton>
                    <div class="spinner-border align-middle"></div>
                }
                else
                {
                    <ReactiveButton MinExecutionTime="TimeSpan.Zero" Class="btn btn-primary" IsEnabled="@(DataContext.Project != null)" Command="@DataContext.Start">
                        <i class="fa fa-play-circle"></i>
                        Start automatic training
                    </ReactiveButton>
                }
            </ReactiveSection>
        </div>

        <span class="align-self-center mx-2">
            <RadioGroup @bind-Value="DataContext.StopWhenDone" Size="@(AntSizeLDSType.Small)">
                <Radio Value="@(false)">
                    <BootstrapTooltip Title="If set, will be running until stopped manually">
                        Run until stopped
                    </BootstrapTooltip>
                </Radio>
                <Radio Value="@(true)">
                    <BootstrapTooltip Title="If set, will stop training loop after completion on a single training">
                        Run once
                    </BootstrapTooltip>
                </Radio>
            </RadioGroup>
        </span>

        <a href="https://wiki.eyeauras.net/en/YoloEase/how-to-use-automatic-trainer">
            <i class="fa fa-external-link align-middle m-2"></i>
        </a>

        <div class="flex-grow-1"></div>
        <div class="d-flex">
            <div class="align-self-center">
                <RadioGroup @bind-Value="DataContext.TrainingMode" Size="@(AntSizeLDSType.Small)">
                    <Radio Value="@(AutomaticTrainerMode.Local)" Class="text-body">
                        <img src="/assets/images/desktop-computer-svgrepo-com.svg" alt="Google Colab Logo" width="16" height="16"/>
                        Local Training
                    </Radio>
                    <Radio Value="@(AutomaticTrainerMode.GoogleColab)" Class="text-body">
                        <img src="/assets/images/Google_Colaboratory_SVG_Logo.svg" alt="Google Colab Logo" width="16" height="16"/>
                        Google Colab
                        <a href="https://colab.research.google.com/drive/15rofeDJtaRe4avg6We_JiVd-P4qQHDYj?usp=sharing">
                            <i class="fa fa-external-link align-middle m-2"></i>
                        </a>
                    </Radio>
                </RadioGroup>
                
            </div>
            <ReactiveButton MinExecutionTime="TimeSpan.Zero" Command="@DataContext.ClearTimeline">
                <i class="fa fa-refresh"></i>
                Clear
            </ReactiveButton>
        </div>
    </div>
    </TopBar>

    <ChildContent>
    @if (DataContext.Project == null)
    {
        <div class="trainer-workspace">
            <div class="trainer-main">
                <div class="alert alert-secondary m-2">
                    No project loaded.
                </div>
            </div>
        </div>
    }
    else
    {
    <div class="trainer-workspace">
    <div class="trainer-main">
        <div class="trainer-timeline-scroll scroller overflow-x-hidden overflow-y-auto">
            <ReactiveSection Trackers="@(new ReactiveTrackerList().With(this.WhenAnyValue(x => x.DataContext.Timeline)))">
                @if (DataContext.Timeline.Count > 0)
                {
                    <Timeline Class="trainer-timeline" Mode="TimelineMode.Left">
                        @foreach (var entry in DataContext.Timeline.Items)
                        {
                            <TrainerTimelineItemWrapper DataContext="@entry"/>
                        }
                    </Timeline>
                }
                else
                {
                    <div class="alert alert-secondary">
                        Timeline of events will be displayed here. Click "Start" to kick-off training process
                    </div>
                }
            </ReactiveSection>

            <div class="scroller-anchor"></div>
        </div>

        <ReactiveSection Trackers="@(new() {this.WhenAnyValue(x => x.DataContext.ShowSettings)})">
            @if (DataContext.ShowSettings)
            {
                <span class="vr mx-1"></span>

                <div class="trainer-settings-scroll">
                    <AutomaticTrainerTaskSettings DataContext="@DataContext"/>
                </div>
            }
        </ReactiveSection>
    </div>

    <div class="trainer-bottombar">
        <div class="trainer-bottom-content">
            <div class="d-flex gap-2">
                <ReactiveButton
                    Class="@Track(x => x.HasUnannotatedFiles ? "btn btn-primary" : "btn btn-secondary")"
                    Command="@(CreateNextTaskAndOpen)">
                    <i class="fa fa-file"></i>
                    Create Task
                </ReactiveButton>
            </div>

            <div class="w-25 mx-2">
                <ProgressBar
                    Maximum="@Track(x => x.ProjectFileCount)"
                    Value="@Track(x => x.AnnotatedFileCount)">
                    <div class="mx-2">
                        @Track(x => $"{x.AnnotatedFileCount} / {x.ProjectFileCount}")
                    </div>
                </ProgressBar>
            </div>
            <div class="flex-grow-1 text-center">
                <ReactiveButton Class="btn btn-link"
                                Command="@(() => DataContext.Refresh())">
                    <i class="fa fa-refresh"></i>
                    Refresh
                </ReactiveButton>
            </div>

            <div class="w-25 mx-2">
                <ProgressBar
                    Maximum="@Track(x => x.ProjectTaskCount)"
                    Value="@(Track(x => x.AnnotatedTaskCount))">
                    <div class="mx-2">
                        @Track(x => $"{x.AnnotatedTaskCount} / {x.ProjectTaskCount}")
                    </div>
                </ProgressBar>
            </div>
            <Modal Title="@("Unannotated Tasks")"
                   Centered="true"
                   Visible="taskListIsVisible"
                   OnOk="@(() => taskListIsVisible = false)"
                   OnCancel="@(() => taskListIsVisible = false)">
                <div class="flex">
                    <div class="align-self-center">
                        <RadioGroup @bind-Value="DataContext.TaskFilter" Size="large">
                            <Radio Value="@(AutomaticTrainerTaskFilter.All)" Class="text-body">
                                All tasks
                            </Radio>
                            <Radio Value="@(AutomaticTrainerTaskFilter.Unannotated)" Class="text-body">
                                Only Unannotated
                            </Radio>
                        </RadioGroup>
                    </div>

                    <div class="flex-grow-1">
                        <Table TItem="AnnotationTaskInfo" DataSource="@(Track(x => x.FilteredTasks))">
                            <PropertyColumn Property="x => x.Name" Title="Name">
                                @Track(context, x => x.Name)
                            </PropertyColumn>
                            <ActionColumn>
                                <ReactiveButton Class="btn btn-link" Command="@(async () => await NavigateToTask(context.Id))">
                                    <i class="fa fa-play-circle-o"></i>
                                </ReactiveButton>
                            </ActionColumn>
                            <ActionColumn>
                                <ReactiveButton Class="btn btn-link" Command="@(async () => await NavigateToTask(context.Id))">
                                    <i class="fa fa-link"></i>
                                </ReactiveButton>
                            </ActionColumn>
                            <ActionColumn Width="60" Class="text-sm-center">
                                <span class="ye-two-step-icon-group">
                                    @if (pendingDeleteTaskId == context.Id)
                                    {
                                        <ReactiveButton Class="btn btn-link text-danger" Command="@(async () => await ConfirmDeleteTask(context.Id))">
                                            <i class="fa fa-check"></i>
                                        </ReactiveButton>
                                        <button type="button" class="btn btn-link" @onclick="CancelDeleteTask">
                                            <i class="fa fa-times"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-link text-danger ye-two-step-primary" @onclick="() => BeginDeleteTask(context.Id)">
                                            <i class="fa fa-remove"></i>
                                        </button>
                                    }
                                </span>
                            </ActionColumn>
                        </Table>
                    </div>
                </div>
            </Modal>
            <ReactiveButton
                IsEnabled="@(Track(x => x.HasUnannotatedTasks))"
                Class="@(Track(x => x.HasUnannotatedTasks ? "btn btn-primary" : "btn btn-secondary"))"
                Command="@(async () => await OpenFirstUnfinishedTask())">
                <i class="fa fa-link"></i>
                Annotate Task
            </ReactiveButton>
            <ReactiveButton
                Class="btn btn-secondary"
                MinExecutionTime="TimeSpan.Zero"
                Command="@(async () => { taskListIsVisible = true; StateHasChanged(); })">
                <i class="fa fa-list"></i>
            </ReactiveButton>
            <ToggleButton @bind-IsChecked="@DataContext.ShowSettings">
                <i class="fa fa-cog"></i>
            </ToggleButton>
        </div>
    </div>
    </div>
    }
    </ChildContent>
</TabPageLayout>

@code {
    bool taskListIsVisible;
    int? pendingDeleteTaskId;

    [Inject]
    protected INotificationService NotificationService { get; init; } = default!;

    [Inject]
    protected IFactory<IBlazorWindow, System.Windows.Threading.Dispatcher> BlazorWindowFactory { get; init; } = default!;

    [Inject]
    protected IBlazorWindowAccessor BlazorWindowAccessor { get; init; } = default!;

    private async Task CreateNextTaskAndOpen()
    {
        try
        {
            var project = DataContext.Project ?? throw new InvalidOperationException("No project is loaded");
            var task = await DataContext.CreateNextTask();
            if (!ReferenceEquals(DataContext.Project, project))
            {
                return;
            }

            await TaskAnnotationWindowLauncher.Open(project, task, BlazorWindowAccessor, BlazorWindowFactory);
        }
        catch (Exception e)
        {
            ShowError(e.Message);
        }
    }

    private async Task OpenFirstUnfinishedTask()
    {
        try
        {
            var project = DataContext.Project ?? throw new InvalidOperationException("No project is loaded");
            var task = project.TrainingBatch.UnannotatedTasks.Items
                .OrderBy(x => x.CreatedAt ?? x.UpdatedAt ?? DateTimeOffset.MaxValue)
                .ThenBy(x => x.Id)
                .FirstOrDefault();
            if (task == null)
            {
                throw new InvalidOperationException("No unfinished tasks to annotate");
            }

            if (!ReferenceEquals(DataContext.Project, project))
            {
                return;
            }

            await TaskAnnotationWindowLauncher.Open(project, task, BlazorWindowAccessor, BlazorWindowFactory);
        }
        catch (Exception e)
        {
            ShowError(e.Message);
        }
    }

    private void BeginDeleteTask(int taskId)
    {
        pendingDeleteTaskId = taskId;
    }

    private void CancelDeleteTask()
    {
        pendingDeleteTaskId = null;
    }

    private async Task NavigateToTask(int taskId)
    {
        try
        {
            var project = DataContext.Project ?? throw new InvalidOperationException("No project is loaded");
            await project.RemoteProject.NavigateToTask(taskId);
        }
        catch (Exception e)
        {
            ShowError(e.Message);
        }
    }

    private async Task ConfirmDeleteTask(int taskId)
    {
        try
        {
            var project = DataContext.Project ?? throw new InvalidOperationException("No project is loaded");
            await project.RemoteProject.DeleteTask(taskId);
            pendingDeleteTaskId = null;
            if (ReferenceEquals(DataContext.Project, project))
            {
                await project.Refresh();
            }
        }
        catch (Exception e)
        {
            ShowError(e.Message);
        }
    }

    private void ShowError(string message)
    {
        NotificationService.Open(new NotificationConfig
        {
            NotificationType = NotificationType.Error,
            Duration = 8,
            Message = message,
        }).AndForget();
    }
}
