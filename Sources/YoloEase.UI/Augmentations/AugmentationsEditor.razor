@using BlazorComponentUtilities
@inherits PoeShared.Blazor.BlazorReactiveComponent<YoloEase.UI.Augmentations.AugmentationsAccessor>

<TabPageLayout Class="augmentations-tab" BodyClass="augmentations-page">
    <TopBar>
        <div class="ye-tab-title-row">
            <span class="ye-tab-title">Augmentations</span>
            <span class="ye-tab-subtitle">Create image variations for training.</span>
        </div>

        <div class="flex-grow-1"></div>

        <ReactiveButton Class="btn btn-primary btn-sm" Command="@(async () => await augmentationDialogRef!.Show())">
            <i class="fa fa-add"></i>
            Add
        </ReactiveButton>
    </TopBar>

    <ChildContent>
        <YeTable HasItems="@(DataContext.Effects.Items.Any())">
            <Header>
                <tr>
                    <th class="ye-check-column"></th>
                    <th>Name</th>
                    <th>Properties</th>
                    <th class="text-end">Actions</th>
                </tr>
            </Header>
            <Rows>
                @foreach (var effect in DataContext.Effects.Items)
                {
                    var localEffect = effect;
                    var contentClass = localEffect.IsEnabled ? null : "strikeout-warning";
                    <tr>
                        <td class="ye-check-column">
                            <ReactiveCheckBox @bind-IsChecked="@localEffect.IsEnabled"/>
                        </td>
                        <td>
                            <span class="@contentClass">@localEffect.Name</span>
                        </td>
                        <td>
                            <span class="@contentClass">@localEffect.Description</span>
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm ye-two-step-group">
                                @if (ReferenceEquals(pendingRemoveEffect, localEffect))
                                {
                                    <ReactiveButton Class="btn btn-danger ye-two-step-confirm" Command="@(async () => await ConfirmRemoveEffect(localEffect))">
                                        <i class="fa fa-trash"></i>
                                        Remove
                                    </ReactiveButton>
                                    <button type="button" class="btn btn-secondary ye-two-step-cancel" @onclick="CancelRemoveEffect">
                                        Cancel
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-outline-danger ye-two-step-primary" @onclick="() => BeginRemoveEffect(localEffect)">
                                        Remove
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </Rows>
            <EmptyContent>
                <div class="alert alert-secondary mb-0">No augmentations configured</div>
            </EmptyContent>
        </YeTable>
    </ChildContent>
</TabPageLayout>

<AddAugmentationDialog @ref="@augmentationDialogRef" DataContext="@DataContext"/>

@code {
    private AddAugmentationDialog? augmentationDialogRef;
    private IImageEffect? pendingRemoveEffect;

    public AugmentationsEditor()
    {
        ChangeTrackers.Add(this.WhenAnyValue(x => x.DataContext.Effects));
    }

    private void BeginRemoveEffect(IImageEffect effect)
    {
        pendingRemoveEffect = effect;
    }

    private void CancelRemoveEffect()
    {
        pendingRemoveEffect = null;
    }

    private Task ConfirmRemoveEffect(IImageEffect effect)
    {
        DataContext.Effects.Remove(effect);
        pendingRemoveEffect = null;
        return Task.CompletedTask;
    }
}
